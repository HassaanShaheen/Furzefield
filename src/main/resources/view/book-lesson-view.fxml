<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.flc.controller.BookLessonController"
            styleClass="dashboard-root">
    <top>
        <VBox spacing="0">
            <HBox styleClass="subscreen-toolbar" alignment="CENTER_LEFT" spacing="16">
                <Button text="←  Back to dashboard" onAction="#onBack" styleClass="toolbar-back-button"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Book a lesson" styleClass="toolbar-title"/>
            </HBox>
            <VBox spacing="8" styleClass="dashboard-body">
                <padding>
                    <Insets top="16" right="24" bottom="8" left="24"/>
                </padding>
                <Label text="Select a lesson in the table, then press Book selected lesson." styleClass="header-meta"/>
                <Label fx:id="messageLabel" wrapText="true" maxWidth="900" minHeight="36"
                       styleClass="feedback-banner feedback-info"/>
            </VBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="lessonTable" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets left="24" right="24" bottom="8" top="0"/>
            </BorderPane.margin>
        </TableView>
    </center>
    <bottom>
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <padding>
                <Insets top="8" right="24" bottom="16" left="24"/>
            </padding>
            <Button text="Book selected lesson" onAction="#onBook" styleClass="primary-button"/>
            <Button text="Refresh list" onAction="#onRefresh" styleClass="tile-button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="←  Back to dashboard" onAction="#onBack" styleClass="tile-button"/>
        </HBox>
    </bottom>
</BorderPane>
