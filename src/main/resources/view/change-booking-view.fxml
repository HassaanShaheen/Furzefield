<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.flc.controller.ChangeBookingController"
            styleClass="dashboard-root">
    <top>
        <VBox spacing="0">
            <HBox styleClass="subscreen-toolbar" alignment="CENTER_LEFT" spacing="16">
                <Button text="←  Back to dashboard" onAction="#onBack" styleClass="toolbar-back-button"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Change booking" styleClass="toolbar-title"/>
            </HBox>
            <VBox spacing="10" styleClass="dashboard-body">
                <padding>
                    <Insets top="16" right="24" bottom="8" left="24"/>
                </padding>
                <Label text="1) Select a booking.  2) Choose a target lesson (full lessons and invalid targets are hidden).  3) Apply change."
                       wrapText="true" styleClass="header-meta"/>
                <Label fx:id="messageLabel" wrapText="true" maxWidth="900" minHeight="36"
                       styleClass="feedback-banner feedback-info"/>
            </VBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="16" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets left="24" right="24" bottom="8" top="0"/>
            </BorderPane.margin>
            <Label text="Your bookings" styleClass="field-label"/>
            <TableView fx:id="bookingTable" prefHeight="220" VBox.vgrow="SOMETIMES"/>
            <Label text="Move to this lesson" styleClass="field-label"/>
            <TableView fx:id="lessonTable" prefHeight="260" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
    <bottom>
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <padding>
                <Insets top="8" right="24" bottom="16" left="24"/>
            </padding>
            <Button text="Apply change" onAction="#onApply" styleClass="primary-button"/>
            <Button text="Refresh" onAction="#onRefresh" styleClass="tile-button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="←  Back to dashboard" onAction="#onBack" styleClass="tile-button"/>
        </HBox>
    </bottom>
</BorderPane>
