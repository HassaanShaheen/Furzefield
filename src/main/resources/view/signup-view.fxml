<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.flc.controller.SignupController"
      styleClass="auth-root"
      alignment="TOP_CENTER"
      spacing="0">
    <padding>
        <Insets top="32" right="36" bottom="36" left="36"/>
    </padding>

    <VBox styleClass="auth-card" alignment="CENTER" spacing="16" maxWidth="360">
        <padding>
            <Insets top="32" right="28" bottom="32" left="28"/>
        </padding>

        <Label text="Create your account" styleClass="auth-title"/>
        <Label text="Join Furzefield to book classes and leave reviews." styleClass="auth-subtitle" wrapText="true"/>

        <VBox spacing="6" styleClass="auth-field-group">
            <Label text="Username" styleClass="field-label"/>
            <TextField fx:id="usernameField" promptText="letters, numbers, underscore" styleClass="auth-input"/>
        </VBox>

        <VBox spacing="6" styleClass="auth-field-group">
            <Label text="Full name" styleClass="field-label"/>
            <TextField fx:id="displayNameField" promptText="As shown on your membership" styleClass="auth-input"/>
        </VBox>

        <VBox spacing="6" styleClass="auth-field-group">
            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="At least 6 characters" styleClass="auth-input"/>
        </VBox>

        <VBox spacing="6" styleClass="auth-field-group">
            <Label text="Confirm password" styleClass="field-label"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password" styleClass="auth-input"/>
        </VBox>

        <Label fx:id="errorLabel" styleClass="error-banner" wrapText="true" maxWidth="300"/>

        <Button fx:id="signupButton" text="Create account" styleClass="primary-button" defaultButton="true" maxWidth="Infinity"/>

        <Hyperlink fx:id="loginLink" text="Already have an account? Sign in" styleClass="auth-link"/>
    </VBox>
</VBox>
