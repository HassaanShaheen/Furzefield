<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.flc.controller.LoginController"
      styleClass="auth-root"
      alignment="CENTER"
      spacing="0">
    <padding>
        <Insets top="48" right="40" bottom="40" left="40"/>
    </padding>

    <VBox styleClass="auth-card" alignment="CENTER" spacing="20">
        <padding>
            <Insets top="36" right="32" bottom="36" left="32"/>
        </padding>

        <Label text="Furzefield Leisure Centre" styleClass="auth-brand"/>
        <Label text="Sign in to your account" styleClass="auth-subtitle"/>
        <Label text="Demo members: m01 … m10 — password: flc2026" styleClass="header-meta" wrapText="true" maxWidth="280"/>

        <Label fx:id="successLabel" styleClass="success-banner" wrapText="true" maxWidth="280"/>

        <VBox spacing="8" styleClass="auth-field-group">
            <Label text="Username" styleClass="field-label"/>
            <TextField fx:id="usernameField" promptText="your_username" styleClass="auth-input"/>
        </VBox>

        <VBox spacing="8" styleClass="auth-field-group">
            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="auth-input"/>
        </VBox>

        <Label fx:id="errorLabel" styleClass="error-banner" wrapText="true" maxWidth="280"/>

        <Button fx:id="loginButton" text="Sign in" styleClass="primary-button" defaultButton="true" maxWidth="Infinity"/>

        <Hyperlink fx:id="signupLink" text="New member? Create an account" styleClass="auth-link"/>
    </VBox>
</VBox>
