<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.flc.controller.TimetableController"
            styleClass="dashboard-root">
    <top>
        <VBox spacing="0">
            <HBox styleClass="subscreen-toolbar" alignment="CENTER_LEFT" spacing="16">
                <Button text="←  Back to dashboard" onAction="#onBack" styleClass="toolbar-back-button"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Lesson timetable" styleClass="toolbar-title"/>
            </HBox>
            <VBox spacing="12" styleClass="dashboard-body">
                <padding>
                    <Insets top="16" right="24" bottom="12" left="24"/>
                </padding>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Search by:"/>
                    <ChoiceBox fx:id="filterModeChoice" prefWidth="160"/>
                    <ComboBox fx:id="dayCombo" prefWidth="140" visible="false" managed="false"/>
                    <ComboBox fx:id="exerciseCombo" prefWidth="160" visible="false" managed="false"/>
                    <Button text="Apply filter" onAction="#onApplyFilter" styleClass="primary-button"/>
                </HBox>
                <Label fx:id="hintLabel" styleClass="header-meta" text="Choose how to search, then Apply filter."/>
            </VBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="lessonTable" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets left="24" right="24" bottom="16" top="0"/>
            </BorderPane.margin>
        </TableView>
    </center>
    <bottom>
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <padding>
                <Insets top="8" right="24" bottom="16" left="24"/>
            </padding>
            <Button text="←  Back to dashboard" onAction="#onBack" styleClass="tile-button"/>
        </HBox>
    </bottom>
</BorderPane>
